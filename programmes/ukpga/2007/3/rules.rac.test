- name: marriage_allowance_reduces_tax
  period: 2025
  input:
    employment_income: 30000
    pension_income: 0
    trading_income: 0
    property_income: 0
    savings_income: 0
    dividend_income: 0
    reliefs_total: 0
    gift_aid_net: 0
    pension_contributions_gross: 0
    receives_marriage_allowance: true
    child_benefit_received: 0
  output:
    marriage_allowance_reducer: 252
    # (17430 * 0.20) - 252 = 3234
    income_tax: 3234
